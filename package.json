{
  "name": "gkBlog",
  "private": true,
  "scripts": {
    // 修正：直接执行 Next.js 构建，同时支持 Turbo 调度
    "build": "next build --no-lint",
    "dev": "next dev",  // 修正：直接启动 Next.js 开发服务器（原 "turbo run dev --parallel" 会循环调用）
    "lint": "next lint",  // 修正：使用 Next.js 自带的 lint 命令
    "clean": "turbo run clean",  // 保留：清理命令可继续使用 Turbo
    "format": "prettier --write .",
    "start": "next start"  // 修正：直接启动 Next.js 生产服务器
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.3.3",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "17.1.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.2",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "vercel": "^44.7.3"
  }
}
